namespace cx::enu {

#define derivIn(x) typename cx::uti::rm_cvref<decltype(x)>::Deriv
#define underIn(x) typename cx::uti::rm_cvref<decltype(x)>::Under
#define valueIn(x) typename cx::uti::rm_cvref<decltype(x)>::Value

template<typename Derived, typename RawEnum, cx::str::StringReference const Names[]>
struct EnumBase;

CX_CONCEPT_GEN_TEMPL(
  EnumBase, is_enum_base, CEnumBase,
  VA_(typename Derived, typename RawEnum, str::StringReference const Names[]),
  VA_(Derived, RawEnum, Names));
#define Enum_Base cx::enu::CEnumBase auto

template<CEnumBase Enu>
finline onedef cexpr proc to_integral(Enu const& e) noexce -> Enu::Under;

template<CEnumBase Enu>
finline onedef cexpr proc from_integral(typename Enu::Under val) noexce -> Enu::Under;

template<CEnumBase Enu>
finline onedef cexpr proc create(typename Enu::Value val) noexce -> Enu::Deriv;

template<CEnumBase Enu, str::CStringReference Str>
finline onedef cexpr proc get_name(Enu const& e) noexce -> Str;

template<typename Derived, typename RawEnum, str::StringReference const Names[]>
struct EnumBase {
  using Value = RawEnum;
  using Under = std::underlying_type_t<Value>;
  using Deriv = Derived;

  glob twide cexpr str::StringReference const* names = Names;

  Value val{};

  cexpr EnumBase() = default;

  implicit cexpr operator Value(this auto const& e) { return e.val; }
  implicit cexpr operator bool() const = delete;
};

template<CEnumBase Enu>
finline onedef cexpr proc to_integral(Enu const& e) noexce -> Enu::Under
{
  return Enu::Under(e.val);
}

template<CEnumBase Enu>
finline onedef cexpr proc from_integral(Enu const& e) -> Enu::Deriv
{
  return create(Enu::Value(e) > (e.val));
}

template<CEnumBase Enu>
finline onedef cexpr proc create(typename Enu::Value val) noexce -> Enu::Deriv
{
  Enu res;
  res.val = val;
  return res;
}

template<CEnumBase Enu>
finline onedef cexpr proc from_integral(typename Enu::Under val) noexce -> Enu::Deriv
{
  return create(Enu::Value(val));
}

template<CEnumBase Enu, str::CStringReference Str>
finline onedef cexpr proc get_name(Enu const& e) noexce -> Str
{
  return e.names[to_integral(e)];
}

onedef cexpr proc write(Enum_Base const& e, llvm::raw_ostream& out) noexce -> void
{
  out << enu::get_name(e);
}

#define CX_DEF_RAW_ENUM_CLASS_NO_NAMES(EnumStructName, Under) \
  enum struct EnumStructName##Value : Under

#define CX_DEF_RAW_ENUM_W_NAMES(EnumStructName, enum_names_prefix, Under)   \
  cx::str::StringReferenceLiteral const extern enum_names_prefix##_names[]; \
  CX_DEF_RAW_ENUM_CLASS_NO_NAMES(EnumStructName, Under)

#define CX_RAW_ENUM_ENUMERATOR(Name) Name,

#define CX_ENUM_BASE_CRTP(EnumStructName, DerivedName, enum_names_prefix)          \
  cx::enu::EnumBase<DerivedName, EnumStructName##Value, enum_names_prefix##_names>

#define CX_ENUM_BASE(EnumStructName)                                \
  CX_ENUM_BASE_CRTP(EnumStructName, EnumStructName, EnumStructName)

#define CX_ENUM_CONSTANT_DECLARATION(Name) static const Deriv Name;

#define CX_ENUM_CONSTANT_DEFINITION(EnumStructName, Name)                       \
  cexpr EnumStructName EnumStructName::Name = EnumStructName::make(Value::Name);

#define CX_INLINE_ENUM_CONSTANT_DEFINITION(Name)                                 \
  static cexpr const typename Base : Deriv& Name = Base::make(Base::Value::Name);

#define CX_DEFINE_ENUM_CLASS_NAMES(EnumStructName)              \
  cexpr cx::str::StringReferenceLiteral EnumStructName##Names[]

#define CX_ENUM_CLASS_NAME_STRING(Name) #Name,

}  // namespace cx::enu
