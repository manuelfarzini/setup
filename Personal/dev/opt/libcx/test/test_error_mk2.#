#include <o_error_mk2.hh>
#include "catch/catch_amalgamated.hh"


auto test_tuple() -> Result_Pair {
  if (std::rand() % 10 > 4) {
    return o_argument_error(0, "test_tuple message");
  }
  return o_result(42);
}

