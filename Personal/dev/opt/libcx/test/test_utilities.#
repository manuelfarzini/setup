/** @file test/misc_test.cpp */

#include <catch/catch_amalgamated.hh>
#include <o_io.hh>


proc test_utilities_func() -> void {
  auto res = pr(int a, int b) {
    return std::pair<int, int>(a, b);
  }
  (1, 2);

  io::printfn("res = ({}, {})", res.first, res.second);
}

proc test_utilities_icount_of() -> void {
  int arr[] = {1, 2, 3};
  icount_of(arr);
}

proc test_utilities_utils_4() -> void {
  u8 src[10] = {1, 2, 3, 4, 5, 6, 7, 8, 9};
  char s[4] = o_extract_4(ccast(char) src);
  char t[4] = o_extract_reverse_4(s);
  char* pc = new char[4] o_extract_reverse_4(ccast(char) src);
  pc = new char[4] o_extract_reverse_4(ccast(char) src);
  u8* pu = new u8[4] o_extract_reverse_4(ccast(u8) s);
  char r[5] = o_extract_reverse_null_4(ccast(char) src);
  u8* pun = new u8[5] o_extract_reverse_null_4(ccast(u8) s);
  char* cun = new char[5] o_extract_null_4(ccast(char) * (4 + &src));
}

proc test_utilities_offset_of() -> void {
  struct {
    int a = 0;
    int b = 42;
  } c;
  isz x = o_offset_of(decltype(c), b);
}

TEST_CASE("test_utilities") {
  o_test("test_utilities_func", test_utilities_func);
  o_test("test_utilities_utils_4", test_utilities_utils_4);
  o_test("test_utilities_icount_of", test_utilities_icount_of);
  o_test("test_utilities_offset_of", test_utilities_offset_of);
}
