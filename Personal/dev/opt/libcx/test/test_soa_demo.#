using fast_io::mnp::chvw;

void test_short_string() {
  auto res1 = ShortString<>::make("Walter");
  auto res2 = ShortString<>::make(std::string("White"));
  std::string source3 = "Heisenberg";
  auto res3 = ShortString<>::make(source3);
  char source4[] = "Jesse";
  auto res4 = ShortString<>::make(source4);
  char* source5 = (char*) malloc(8 * sizeof(char));
  std::memmove(source5, "Pinkman", 8);
  auto res5 = ShortString<>::make(source5);
  std::string source6;
  std::getline(std::cin, source6);
  auto res6 = ShortString<>::make(source6);

  ShortString<> s1 = *res1;
  ShortString<> s2 = *res2;
  ShortString<> s3 = *res3;
  ShortString<> s4 = *res4;
  ShortString<> s5 = *res5;
  ShortString<> s6 = *res6;

  io::println(static_cast<string>(s1));
  io::println(static_cast<string>(s2));
  io::println(static_cast<string>(s3));
  io::println(static_cast<string>(s4));
  io::println(static_cast<string>(s5), " ", 5);
  io::println(static_cast<string>(s6));

  for (int i = 0; i < s5.size(); i++)
    io::print(*(s5.data() + i), " ");
  io::println("");

  for (int i = 0; i < s5.size(); i++)
    io::print(chvw(*s5[i]), " ");
  io::println("");

  for (auto& c : s5)
    io::print(chvw(c));
  io::println("");

  io::println(chvw(*s3[0]), " ", s3.size());
}

